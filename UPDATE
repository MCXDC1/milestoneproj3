 def request_enroll(self, student, enroll_date):
        "checks prerequisites first. if a student is enrolled first and if there is space. if theres space then it puts then in the queue"
        """Paris"""
        student_courses = {c.course_code for c in student.get_courses()}

        for prereq in self.prerequisites.items():
            key = prereq[0]
            if key not in student_courses:
                raise Exception(f"Missing prerequisite: {key}")
            

        for record in self.enrolled:
            if record.student.student_id == student.student_id:
                return  
        if len(self.enrolled) < self.capacity:
            record = EnrollmentRecord(student, enroll_date)
            self.enrolled.append(record)
        else:
            self.waitlist.enqueue(student)

 def sort_enrolled(self, by, algorithm="merge"):
        "Mergesort + quicksort"
        "Paris"
        EnrollmentRecord.key = by

        if algorithm == "merge":
            mergesort(self.enrolled)  
        elif algorithm == "quick":
            self.enrolled = quicksort(self.enrolled)   
        else:
            raise ValueError("Invalid algorithm")

        self.sorted_by = by

def quicksort(l):
    if len(l) <= 1:
        return l

    pivot = l[0]
    left = []
    right = []

    for x in l[1:]:
        if x < pivot:
            left.append(x)
        else:
            right.append(x)

    return quicksort(left) + [pivot] + quicksort(right)

def mergesort(l):
    if len(l) < 2:
        return l 
    
    mid = len(l)//2
    a = l[:mid]
    b = l[mid:]

    mergesort(a)
    mergesort(b)
    merge(a, b, l)
    return l 

def merge(a, b, l):
    i = 0
    j = 0

    while i < len(a) and j < len(b):   # FIXED
        if a[i] < b[j]:
            l[i+j] = a[i]
            i += 1
        else:
            l[i+j] = b[j]
            j += 1

    l[i+j:] = a[i:] + b[j:]
